{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Custom Optimization Strategies\n",
    "\n",
    "Learn how to define and evaluate your own pruning/quantization strategies."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from atropos import DeploymentScenario, OptimizationStrategy, estimate_outcome\n",
    "from atropos.presets import SCENARIOS\n",
    "import pandas as pd"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Define Custom Strategies\n",
    "\n",
    "Create strategies based on your own benchmarks or research."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Based on your own measurements\n",
    "my_strategy = OptimizationStrategy(\n",
    "    name=\"my_measured_strategy\",\n",
    "    parameter_reduction_fraction=0.25,  # 25% of params removed\n",
    "    memory_reduction_fraction=0.20,      # 20% memory saved\n",
    "    throughput_improvement_fraction=0.15, # 15% faster\n",
    "    power_reduction_fraction=0.12,       # 12% less power\n",
    "    quality_risk=\"low\",                 # Minimal quality impact\n",
    ")\n",
    "\n",
    "# Aggressive pruning for cost-sensitive applications\n",
    "aggressive = OptimizationStrategy(\n",
    "    name=\"aggressive_cost_cutting\",\n",
    "    parameter_reduction_fraction=0.50,\n",
    "    memory_reduction_fraction=0.40,\n",
    "    throughput_improvement_fraction=0.35,\n",
    "    power_reduction_fraction=0.25,\n",
    "    quality_risk=\"high\",\n",
    ")\n",
    "\n",
    "# Conservative for quality-critical applications\n",
    "conservative = OptimizationStrategy(\n",
    "    name=\"conservative_quality_first\",\n",
    "    parameter_reduction_fraction=0.10,\n",
    "    memory_reduction_fraction=0.08,\n",
    "    throughput_improvement_fraction=0.05,\n",
    "    power_reduction_fraction=0.04,\n",
    "    quality_risk=\"low\",\n",
    ")\n",
    "\n",
    "custom_strategies = [my_strategy, aggressive, conservative]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Evaluate Custom Strategies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scenario = SCENARIOS['medium-coder']\n",
    "\n",
    "results = []\n",
    "for strategy in custom_strategies:\n",
    "    outcome = estimate_outcome(scenario, strategy)\n",
    "    results.append({\n",
    "        'Strategy': strategy.name,\n",
    "        'Param Reduction %': strategy.parameter_reduction_fraction * 100,\n",
    "        'Memory Reduction %': strategy.memory_reduction_fraction * 100,\n",
    "        'Throughput Gain %': strategy.throughput_improvement_fraction * 100,\n",
    "        'Annual Savings ($)': outcome.annual_total_savings_usd,\n",
    "        'Break-even (mo)': outcome.break_even_years * 12 if outcome.break_even_years else None,\n",
    "        'Risk': strategy.quality_risk,\n",
    "    })\n",
    "\n",
    "pd.DataFrame(results)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Strategy Optimization\n",
    "\n",
    "Find the optimal strategy parameters for a target break-even time."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Grid search over parameter space\n",
    "import numpy as np\n",
    "\n",
    "target_break_even_months = 12\n",
    "best_strategy = None\n",
    "closest_diff = float('inf')\n",
    "\n",
    "search_results = []\n",
    "\n",
    "for mem_red in np.arange(0.10, 0.40, 0.05):\n",
    "    for thr_gain in np.arange(0.05, 0.30, 0.05):\n",
    "        strategy = OptimizationStrategy(\n",
    "            name=f\"search_{mem_red:.2f}_{thr_gain:.2f}\",\n",
    "            parameter_reduction_fraction=mem_red * 1.2,\n",
    "            memory_reduction_fraction=mem_red,\n",
    "            throughput_improvement_fraction=thr_gain,\n",
    "            power_reduction_fraction=mem_red * 0.6,\n",
",
    "            quality_risk=\"medium\" if mem_red > 0.25 else \"low\",\n",
    "        )\n",
    "        \n",
    "        outcome = estimate_outcome(scenario, strategy)\n",
    "        \n",
    "        if outcome.break_even_years:\n",
    "            be_months = outcome.break_even_years * 12\n",
    "            diff = abs(be_months - target_break_even_months)\n",
    "            \n",
    "            if diff < closest_diff:\n",
    "                closest_diff = diff\n",
    "                best_strategy = strategy\n",
    "            \n",
    "            search_results.append({\n",
    "                'Memory Reduction': mem_red,\n",
    "                'Throughput Gain': thr_gain,\n",
    "                'Break-even (mo)': be_months,\n",
    "                'Annual Savings': outcome.annual_total_savings_usd,\n",
    "            })\n",
    "\n",
    "print(f\"Best strategy found:\")\n",
    "print(f\"  Memory Reduction: {best_strategy.memory_reduction_fraction:.0%}\")\n",
    "print(f\"  Throughput Gain: {best_strategy.throughput_improvement_fraction:.0%}\")\n",
    "print(f\"  Break-even: {closest_diff + target_break_even_months:.1f} months\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize the search space\n",
    "search_df = pd.DataFrame(search_results)\n",
    "pivot = search_df.pivot_table(\n",
    "    values='Break-even (mo)',\n",
    "    index='Memory Reduction',\n",
    "    columns='Throughput Gain'\n",
    ")\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.contourf(pivot.columns, pivot.index, pivot.values, levels=20)\n",
    "plt.colorbar(label='Break-even (months)')\n",
    "plt.xlabel('Throughput Gain')\n",
    "plt.ylabel('Memory Reduction')\n",
    "plt.title('Strategy Parameter Space')\n",
    "plt.axhline(y=best_strategy.memory_reduction_fraction, color='r', linestyle='--')\n",
    "plt.axvline(x=best_strategy.throughput_improvement_fraction, color='r', linestyle='--')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Save Strategy for Reuse"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yaml\n",
    "\n",
    "strategy_dict = {\n",
    "    'name': best_strategy.name,\n",
    "    'parameter_reduction_fraction': best_strategy.parameter_reduction_fraction,\n",
    "    'memory_reduction_fraction': best_strategy.memory_reduction_fraction,\n",
    "    'throughput_improvement_fraction': best_strategy.throughput_improvement_fraction,\n",
    "    'power_reduction_fraction': best_strategy.power_reduction_fraction,\n",
    "    'quality_risk': best_strategy.quality_risk,\n",
    "}\n",
    "\n",
    "with open('../my_optimized_strategy.yaml', 'w') as f:\n",
    "    yaml.dump(strategy_dict, f)\n",
    "\n",
    "print(\"Saved strategy to my_optimized_strategy.yaml\")"
   ]
  }
 ],
