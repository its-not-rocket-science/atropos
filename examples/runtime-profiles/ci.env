# CI profile (in-memory store, auth-enabled hardening)
ATROPOS_RUNTIME_PROFILE=ci
ATROPOS_HARDENING_TIER=internal-team-safe
ATROPOS_STORE_BACKEND=memory
# Override this in CI secret manager if desired
ATROPOS_API_TOKEN=ci-test-token
ATROPOS_ALLOWED_ORIGINS=https://ci.example.internal
ATROPOS_TRACING_ENABLED=false
