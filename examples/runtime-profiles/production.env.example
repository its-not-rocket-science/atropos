# Production profile (durable + explicit observability)
ATROPOS_RUNTIME_PROFILE=production
ATROPOS_HARDENING_TIER=production-safe
ATROPOS_STORE_BACKEND=redis
ATROPOS_REDIS_URL=redis://redis:6379/0
ATROPOS_API_TOKEN=replace-with-secret-token
ATROPOS_ALLOWED_ORIGINS=https://api.example.com,https://admin.example.com
ATROPOS_TRACING_ENABLED=true
ATROPOS_TRACING_EXPORTER=otlp
ATROPOS_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
ATROPOS_LOG_FORMAT=json
